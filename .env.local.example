# Auth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET=

# Login credentials
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Neon PostgreSQL — get from https://console.neon.tech/
DATABASE_URL=

# Google Calendar API
# Setup (one-time):
#   1. Go to https://console.cloud.google.com/ → create a project
#   2. Enable the Google Calendar API
#   3. Create OAuth 2.0 credentials (Desktop app type)
#   4. Run this to get a refresh token (replace CLIENT_ID and CLIENT_SECRET):
#      open "https://accounts.google.com/o/oauth2/auth?client_id=CLIENT_ID&redirect_uri=urn:ietf:wg:oauth:2.0:oob&response_type=code&scope=https://www.googleapis.com/auth/calendar.readonly"
#   5. Exchange the code: curl -X POST https://oauth2.googleapis.com/token \
#        -d client_id=CLIENT_ID -d client_secret=CLIENT_SECRET \
#        -d code=CODE -d grant_type=authorization_code \
#        -d redirect_uri=urn:ietf:wg:oauth:2.0:oob
#   6. Copy the refresh_token from the response
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
